# ── le fournisseur LLM ─────────────────────────────────────────────────
LLM_PROVIDER=groq

# ══════════════════════════════════════════════════════════════════════════════
#  OPTION 1 — GROQ (RECOMMANDÉ)  ⚡ Ultra-rapide, gratuit
#  Inscription : https://console.groq.com  
# ══════════════════════════════════════════════════════════════════════════════
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.1-8b-instant

# ── MongoDB ────────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
DB_NAME=uniassist

# ── Auth ───────────────────────────────────────────────────────────────────────
ADMIN_PASSWORD=admin@iit2025
JWT_SECRET=uniassist-secret-changez-moi
TOKEN_EXPIRY_HOURS=24

# ── Limites ────────────────────────────────────────────────────────────────────
MAX_PDF_SIZE_MB=20
